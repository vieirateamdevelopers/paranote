<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_sheet_camera"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundColor">

    <include layout="@layout/bottom_sheet_toolbar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="@dimen/layout_margin_max">

        <androidx.camera.view.PreviewView
            android:id="@+id/camera_view"
            android:layout_width="match_parent"
            android:layout_height="@dimen/preview_view_height"
            android:scaleType="fitCenter"
            tools:ignore="MissingConstraints" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/floating_button_camera"
            android:layout_width="@dimen/floating_button_big"
            android:layout_height="@dimen/floating_button_big"
            android:src="@drawable/ic_drawable_camera"
            android:tint="@color/colorLightMode"
            android:layout_marginBottom="@dimen/layout_margin_min"
            app:fabCustomSize="@dimen/floating_button_big"
            android:contentDescription="@string/menu_camera"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/text_view_scan" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/text_view_scan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/layout_margin_min"
            android:text="@string/text_view_scan_text_desc"
            android:textAlignment="center"
            android:textColor="?attr/backgroundViewColor"
            android:textSize="@dimen/text_body_min"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>