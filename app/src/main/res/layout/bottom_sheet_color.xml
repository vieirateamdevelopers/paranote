<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottom_sheet_color"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/backgroundColor">

    <include layout="@layout/bottom_sheet_toolbar" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbarSize="@dimen/scrollbar_size_min"
        android:scrollbarThumbVertical="@color/colorAccent"
        android:scrollbarFadeDuration="@integer/scrollbar_fade_duration">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="@dimen/layout_margin_max"
            android:layout_marginBottom="@dimen/layout_margin_big">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_1"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="?attr/backgroundToolbarColor"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_2"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet2"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_3"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet3"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_4"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet4"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_5"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet5"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/layout_margin_big">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_6"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet6"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_7"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet7"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_8"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet8"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_9"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet9"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_10"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet10"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/layout_margin_big">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_11"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet11"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_12"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet12"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_13"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet13"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_14"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet14"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_15"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet15"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/layout_margin_big">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_16"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet16"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_17"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet17"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_18"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet18"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_19"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:layout_marginEnd="@dimen/layout_padding_max"
                    android:src="@color/colorSheet19"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/image_view_color_20"
                    android:layout_width="@dimen/floating_button_max"
                    android:layout_height="@dimen/floating_button_max"
                    android:src="@color/colorSheet20"
                    app:civ_border_color="@color/colorFabMenu"
                    app:civ_border_width="0.5dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    
</LinearLayout>