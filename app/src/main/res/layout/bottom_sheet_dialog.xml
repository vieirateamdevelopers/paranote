<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_sheet_dialog"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/layout_margin_max"
    android:background="?attr/backgroundColor">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/text_view_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textAlignment="center"
        android:textColor="?attr/backgroundViewColor"
        android:textSize="@dimen/text_title_max" />

    <ProgressBar
        android:layout_width="@dimen/progress_bar_height"
        android:layout_height="@dimen/progress_bar_height"
        android:elevation="@dimen/elevation_dialog"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:progressTint="@color/colorAccent"
        android:layout_marginTop="@dimen/layout_margin_max"
        android:layout_marginBottom="@dimen/layout_margin_max" />

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="@string/text_view_progress"
        android:textColor="?attr/backgroundViewColor"
        android:textSize="@dimen/text_body_max" />

</LinearLayout>