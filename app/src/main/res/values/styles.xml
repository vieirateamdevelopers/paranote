<resources>

    <style name="IntroTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <style name="LightTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/colorLightMode</item>
        <item name="colorPrimaryDark">@color/colorLightMode</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="backgroundColor">@color/colorLightMode</item>
        <item name="foregroundColor">@color/colorAccent</item>
        <item name="backgroundViewColor">@color/colorLightViews</item>
        <item name="foregroundViewColor">@color/colorAccent</item>
        <item name="backgroundToolbarColor">@color/colorLightToolbar</item>
        <item name="android:textColorHint">@color/colorTextHint</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="actionModeStyle">@style/LightActionMode</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <style name="DarkTheme" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/colorDarkMode</item>
        <item name="colorPrimaryDark">@color/colorDarkMode</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="backgroundColor">@color/colorDarkMode</item>
        <item name="foregroundColor">@color/colorDarkToolbar</item>
        <item name="backgroundViewColor">@color/colorDarkViews</item>
        <item name="foregroundViewColor">@color/colorLightMode</item>
        <item name="backgroundToolbarColor">@color/colorDarkToolbar</item>
        <item name="android:textColorHint">@color/colorTextHint</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="actionModeStyle">@style/DarkActionMode</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationTransition</item>
    </style>

    <style name="LightActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="background">@color/colorAccent</item>
    </style>

    <style name="DarkActionMode" parent="Widget.AppCompat.ActionMode">
        <item name="background">@color/colorAccent</item>
    </style>

    <style name="WindowAnimationTransition">
        <item name="android:windowEnterAnimation">@android:anim/fade_in</item>
        <item name="android:windowExitAnimation">@android:anim/fade_out</item>
    </style>

</resources>
